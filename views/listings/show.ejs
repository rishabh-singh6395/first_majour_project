<% layout("/layouts/boilerplate") %>

<body>
    <div class = "col-md-8 offset-md-4">
    <h3><%=listing.title %></h3>

    <div class="card" style="width: 18rem;">
  <img src="<%= listing.image && listing.image.url ? listing.image.url : '' %>" class="card-img-top" alt="...">
  <div class="card-body">
     <ul>
        <li><%=listing.description %></li>
        <li><%=listing.price %></li>
        <li><%=listing.location %></li>
        <li><%=listing.country %></li>

    </ul>
</div>
</div>

<hr/>
<div class="col-8 offset-3">
    <h4>Reviews</h4>
    <form>
        <div>
            <label for="review">Add a review</label>
            <input type="range" min="1" max="5" name="review[rating]" id="rating" >
        </div>
        <div>
            <label for="comment" >Comments</label> 
            <textarea  rows="10" cols="30" name="review[comment]" id="comment" ></textarea>
        </div>
        <button>Submit</button>
    </form>
</div>
 
   
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark">Edit </a>
    <br/><br/>
    <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-danger">Delete </button>
    </form>
</div>    
</body>
